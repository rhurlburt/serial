# Test environment for main instance E2E tests
# This file is committed to the repo — do not add real secrets

# Prevent Vite from loading the root .env file during tests
VITE_ENV_DIR=tests

# Database
DATABASE_URL=http://127.0.0.1:8081

# Auth
BETTER_AUTH_SECRET=test-secret-key-for-main-tests
VITE_PUBLIC_BASE_URL=http://localhost:3002

# Main instance flag
VITE_PUBLIC_IS_MAIN_INSTANCE=true

VITE_PUBLIC_IS_DEMO_INSTANCE=

# Polar (test values)
POLAR_ENVIRONMENT=sandbox
POLAR_ACCESS_TOKEN=test-token-for-e2e
POLAR_WEBHOOK_SECRET=test-webhook-secret
POLAR_STANDARD_SMALL_QUOTA_MONTHLY_PRODUCT_ID=test-standard-small-monthly
POLAR_STANDARD_SMALL_QUOTA_ANNUAL_PRODUCT_ID=test-standard-small-annual
POLAR_STANDARD_MEDIUM_QUOTA_MONTHLY_PRODUCT_ID=test-standard-medium-monthly
POLAR_STANDARD_MEDIUM_QUOTA_ANNUAL_PRODUCT_ID=test-standard-medium-annual
POLAR_STANDARD_LARGE_QUOTA_MONTHLY_PRODUCT_ID=test-standard-large-monthly
POLAR_STANDARD_LARGE_QUOTA_ANNUAL_PRODUCT_ID=test-standard-large-annual
POLAR_PRO_MONTHLY_PRODUCT_ID=test-pro-monthly
POLAR_PRO_ANNUAL_PRODUCT_ID=test-pro-annual

# Prevent Nitro/c12 from loading these from .env.local
# (Nitro's Vite plugin always loads .env + .env.local in dev mode,
#  independently of Vite's envDir setting. Empty values here claim the
#  slot; emptyStringAsUndefined in src/env.js converts them to undefined.)
RESEND_API_KEY=
SENDGRID_API_KEY=
FROM_EMAIL_ADDRESS=
INSTAPAPER_OAUTH_ID=
INSTAPAPER_OAUTH_SECRET=
SENTRY_DSN_BACKEND=
SENTRY_AUTH_TOKEN=
VITE_PUBLIC_SENTRY_DSN_WEB=
VITE_PUBLIC_SUPPORT_EMAIL_ADDRESS=
