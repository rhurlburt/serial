# REQUIRED - Your base domain url (e.g. https://www.example.com).
VITE_PUBLIC_BASE_URL=

# REQUIRED - Authentication
# Generate a secret here: https://www.better-auth.com/docs/installation#set-environment-variables
# Alternatively, run `openssl rand -base64 32` in a terminal and use that value.
BETTER_AUTH_SECRET=

# Database (only for cloud dbs or local libsql running on a custom port)
# DATABASE_URL='http://127.0.0.1:8080'
# DATABASE_AUTH_TOKEN=

# OAuth (optional, for custom SSO login)
# OAUTH_PROVIDER_ID=
# OAUTH_PROVIDER_NAME=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_DISCOVERY_URL=
# OAUTH_AUTHORIZATION_URL=
# OAUTH_TOKEN_URL=
# OAUTH_USER_INFO_URL=
# OAUTH_SCOPES=
# OAUTH_PKCE=false
# OAUTH_REDIRECT_URI=

# Trusted Origins (optional, comma-separated list of additional origins)
# Use this when the app is accessed through a masked redirect or reverse proxy
# and you need to allow cross-origin auth requests.
# The main instance includes https://www.serial.tube so the marketing site can
# check the session and redirect signed-in visitors to the app.
# TRUSTED_ORIGINS=

# Email (optional — needed for password reset and email verification)
# FROM_EMAIL_ADDRESS is required for email sending to work.
# If both provider keys are set, Resend takes priority.
FROM_EMAIL_ADDRESS=
VITE_PUBLIC_SUPPORT_EMAIL_ADDRESS=

RESEND_API_KEY=
SENDGRID_API_KEY=

# Integrations
INSTAPAPER_OAUTH_ID=
INSTAPAPER_OAUTH_SECRET=

# Key-Value Store (optional — enables durable real-time sync)
# Options: "none" (default), "ioredis" (local Redis), "upstash" (Upstash Redis)
# For Docker self-hosted: automatically set to "ioredis" via docker-compose
# For standalone: set to "upstash" and configure UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# KV_STORE=none
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Analytics
VITE_PUBLIC_UMAMI_WEBSITE_ID=
VITE_PUBLIC_UMAMI_SRC=

# Error Tracking (Sentry/GlitchTip)
VITE_PUBLIC_SENTRY_DSN_WEB=
SENTRY_DSN_BACKEND=

# Share the auth session cookie across subdomains (main instance only) so the
# marketing site can redirect signed-in visitors to the app.
# COOKIE_DOMAIN=.serial.tube

# Misc
# If true, will prevent users from accessing the instance. Useful for performing db/infrastructure updates.
VITE_PUBLIC_IS_MAINTENANCE_MODE=

# You should not use this unless you have a very good reason. This sets up an
# instance with anonymous user registration which has its databases wiped every
# 24 hours (both sqlite and whichever KV store you have configured).
VITE_PUBLIC_IS_DEMO_INSTANCE=
