# Test environment for demo instance E2E tests
# This file is committed to the repo — do not add real secrets

# Prevent Vite from loading the root .env file during tests
VITE_ENV_DIR=tests

# Database
DATABASE_URL=http://127.0.0.1:8083

# Auth
BETTER_AUTH_SECRET=test-secret-key-for-demo-tests
VITE_PUBLIC_BASE_URL=http://localhost:3005

# Demo instance flags
VITE_PUBLIC_IS_MAIN_INSTANCE=false
VITE_PUBLIC_IS_DEMO_INSTANCE=true

# Prevent Nitro/c12 from loading these from .env.local
# (Nitro's Vite plugin always loads .env + .env.local in dev mode,
#  independently of Vite's envDir setting. Empty values here claim the
#  slot; emptyStringAsUndefined in src/env.js converts them to undefined.)
RESEND_API_KEY=
SENDGRID_API_KEY=
FROM_EMAIL_ADDRESS=
INSTAPAPER_OAUTH_ID=
INSTAPAPER_OAUTH_SECRET=
SENTRY_DSN_BACKEND=
SENTRY_AUTH_TOKEN=
VITE_PUBLIC_SENTRY_DSN_WEB=
VITE_PUBLIC_SUPPORT_EMAIL_ADDRESS=
