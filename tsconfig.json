{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "checkJs": true,
    /* Bundled projects */
    "lib": ["dom", "dom.iterable", "es2022"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "incremental": true,
    /* Path Aliases */
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": [".eslintrc.cjs", "**/*.ts", "**/*.tsx", "**/*.cjs", "**/*.js"],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results",
    "dist",
    "dist-sw",
    "**/public/sw.js",
    "**/public/workbox-*.js",
    "**/public/worker-*.js",
    "**/public/sw.js.map",
    "**/public/workbox-*.js.map",
    "**/public/worker-*.js.map"
  ]
}
